featurePrefixes = (
{
code = "###
# OpenType Layout feature definitions
# Format: Adobe FDK for OpenType (AFDKO) version 2.5
# Generated on: 2026-6-14 18:8
# Generated by: FontLab 8.0.0
# Font PostScript name: ContemporaryDisplay-Regular
# Font copyright: Copyright 2026 The Contemporary Display Project Authors (https://volven.me/)
#
# Totals:
# Languagesystems: 7
# GSUB lookups: 63
# GSUB features: 39 (aalt, calt, case, ccmp, cv01, cv02, cv03, cv04, cv05, cv06, cv07, cv08, cv09, cv10, cv11, cv12, cv13, cv14, dlig, dnom, frac, locl, numr, ordn, pnum, salt, sinf, ss01, ss02, ss03, ss04, ss05, ss06, ss07, ss08, subs, sups, tnum, zero)
# GPOS lookups: 2
# GPOS features: 2 (cpsp, kern)

#
# Languagesystem definitions
#

languagesystem DFLT dflt; # Default default
languagesystem latn dflt; # Latin default
languagesystem latn CAT ; # Latin Catalan
languagesystem latn MOL ; # Latin Moldavian
languagesystem latn ROM ; # Latin Romanian
languagesystem cyrl dflt; # Cyrillic default
languagesystem grek dflt; # Greek default

#
# Lookup definitions
#


#
# Feature definitions
#

";
tag = Languagesystems;
}
);
